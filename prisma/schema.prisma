generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TeamMember {
  id        String   @id
  name      String
  email     String?
  password  String?
  grade     String?
  isAdmin   Boolean  @default(false)
  tagOnly   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Customer {
  id           String   @id
  userId       String
  data         String
  status       String?
  company      String?
  createdAt    DateTime @default(now())
  lastActionAt DateTime @default(now())

  @@index([userId])
  @@index([userId, status])
}

model Project {
  id           String   @id
  customerId   String
  title        String
  rmId         String?
  status       String?  @default("신규접수")
  data         String   @default("{}")
  createdAt    DateTime @default(now())
  lastActionAt DateTime @default(now())

  @@index([customerId])
}

model Note {
  id         String  @id
  customerId String
  data       String
  seq        Int     @default(1)
  projectId  String?

  @@index([customerId])
  @@index([projectId])
}

model Rate {
  role     String @id
  category String
  grades   String
}

model Category {
  id    String  @id
  label String
  desc  String?
}

model Perm {
  menuId     String  @id
  rmAllow    Boolean @default(false)
  leadAllow  Boolean @default(false)
  adminAllow Boolean @default(true)
}

model Pattern {
  id        String   @id
  pattern   String
  count     Int      @default(1)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Contract {
  id         String   @id
  userId     String
  projectId  String?
  customerId String?
  data       String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())

  @@index([userId])
  @@index([customerId])
}

model SimilarCase {
  id        String   @id
  userId    String
  data      String   @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
}
